{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/internal/layout,_N_T_/internal/page,_N_T_/internal"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/internal/__PAGE__",
    "/internal",
    "/_index",
    "/_head"
  ]
}